{
  "info": {
    "name": "Salinas IoT Platform API",
    "_postman_id": "8d6b2c2e-f3ae-4c2d-9d5c-2e2c2fd0a001",
    "description": "Colección base para la API del backend IoT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@salinas.local\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "devices"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Create Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rack Temp Sensor 01\",\n  \"type\": \"temperature\",\n  \"location\": { \"rack\": \"A1\", \"position\": 1, \"floor\": 1 },\n  \"status\": \"online\",\n  \"thresholds\": { \"min\": 18, \"max\": 30, \"criticalMin\": 15, \"criticalMax\": 35 },\n  \"metadata\": { \"manufacturer\": \"ACME\", \"model\": \"TMP-100\", \"firmwareVersion\": \"1.0.0\" }\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "devices"]
            }
          }
        }
      ]
    },
    {
      "name": "Readings",
      "item": [
        {
          "name": "Batch Ingest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-system-key", "value": "{{systemKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"readings\": [\n    {\n      \"deviceId\": \"{{deviceId}}\",\n      \"value\": 23.5,\n      \"unit\": \"°C\",\n      \"quality\": \"good\",\n      \"timestamp\": \"2026-06-03T12:00:00.000Z\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/readings/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "readings", "batch"]
            }
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "alerts"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard/overview",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dashboard", "overview"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "systemKey", "value": "local-dev-ingest-key" },
    { "key": "deviceId", "value": "" }
  ]
}
